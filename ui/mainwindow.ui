  <widget class="QWidget" name="centralwidget">
   <widget class="QPushButton" name="BoutonDemarrer">
    <property name="geometry">
     <rect>
      <x>165</x>
      <y>440</y>
      <width>40</width>
      <height>40</height>
     </rect>
    </property>
    <property name="focusPolicy">
     <enum>Qt::NoFocus</enum>
    </property>
    <property name="styleSheet">
     <string notr="true">QPushButton {
    /* Dégradé bleu foncé néon */
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #304ffe,   /* bleu électrique clair */
        stop:1 #1a237e    /* bleu nuit foncé */
    );
    border-radius: 20px;             /* cercle parfait pour 40x40 */
    min-width: 40px;
    min-height: 40px;
    max-width: 40px;
    max-height: 40px;
    color: white;
    font-weight: bold;
    border: none;

    /* Glow néon */
    box-shadow: 0 0 10px #304ffe, 0 0 20px #1a237e;
}

QPushButton:hover {
    /* Glow plus intense au survol */
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #3d5afe,
        stop:1 #283593
    );
    box-shadow: 0 0 15px #3d5afe, 0 0 30px #283593;
}

QPushButton:pressed {
    /* Bouton enfoncé */
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #1a237e,
        stop:1 #0d133e
    );
    box-shadow: 0 0 5px #1a237e, 0 0 10px #0d133e;
    transform: translateY(2px);
}
</string>
    </property>
    <property name="text">
     <string>Start</string>
    </property>
   </widget>
